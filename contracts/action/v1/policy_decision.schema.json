{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autonoma.ai/contracts/action/v1/policy_decision.schema.json",
  "title": "PolicyDecision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "correlation_id",
    "created_at",
    "actor",
    "decision",
    "reasons",
    "risk_level",
    "evaluated_at"
  ],
  "properties": {
    "correlation_id": {
      "type": "string",
      "format": "uuid"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "actor": {
      "type": "object",
      "description": "Entity initiating/emitting this object.",
      "additionalProperties": false,
      "required": ["type", "id"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["user", "agent", "system"]
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "display_name": {
          "type": "string"
        }
      }
    },
    "decision_id": {
      "type": "string"
    },
    "decision": {
      "type": "string",
      "enum": ["allow", "deny", "require_approval"]
    },
    "reasons": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "evaluated_at": {
      "type": "string",
      "format": "date-time"
    },
    "policy_id": {
      "type": "string"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
