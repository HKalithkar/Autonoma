{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autonoma.ai/contracts/action/v1/action_request.schema.json",
  "title": "ActionRequest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "correlation_id",
    "created_at",
    "actor",
    "idempotency_key",
    "intent",
    "target",
    "parameters",
    "environment",
    "tool"
  ],
  "properties": {
    "correlation_id": {
      "type": "string",
      "format": "uuid"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "actor": {
      "type": "object",
      "description": "Entity initiating/emitting this object.",
      "additionalProperties": false,
      "required": ["type", "id"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["user", "agent", "system"]
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "display_name": {
          "type": "string"
        }
      }
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 1
    },
    "intent": {
      "type": "string",
      "minLength": 1
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id"],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "display_name": {
          "type": "string"
        },
        "uri": {
          "type": "string"
        }
      }
    },
    "parameters": {
      "type": "object",
      "additionalProperties": true
    },
    "environment": {
      "type": "string",
      "minLength": 1
    },
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "name"],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string"
        },
        "action": {
          "type": "string"
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
