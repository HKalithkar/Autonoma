{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autonoma.ai/contracts/action/v1/approval_decision.schema.json",
  "title": "ApprovalDecision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "correlation_id",
    "created_at",
    "actor",
    "approval_request_id",
    "status",
    "decided_by",
    "decided_at"
  ],
  "properties": {
    "correlation_id": {
      "type": "string",
      "format": "uuid"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "actor": {
      "type": "object",
      "description": "Entity initiating/emitting this object.",
      "additionalProperties": false,
      "required": ["type", "id"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["user", "agent", "system"]
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "display_name": {
          "type": "string"
        }
      }
    },
    "approval_decision_id": {
      "type": "string"
    },
    "approval_request_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["pending", "approved", "rejected", "expired", "cancelled"]
    },
    "decided_by": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["user", "agent", "system"]
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "display_name": {
          "type": "string"
        }
      }
    },
    "decided_at": {
      "type": "string",
      "format": "date-time"
    },
    "comments": {
      "type": "string"
    },
    "reason": {
      "type": "string"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "oneOf": [
    {
      "properties": {
        "status": {
          "enum": ["approved", "rejected", "expired", "cancelled"]
        }
      }
    }
  ]
}
