{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autonoma.ai/contracts/action/v1/audit_event.schema.json",
  "title": "AuditEvent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "correlation_id",
    "created_at",
    "actor",
    "event_type",
    "event_category",
    "entity",
    "payload_summary",
    "redacted_fields"
  ],
  "properties": {
    "correlation_id": {
      "type": "string",
      "format": "uuid"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "actor": {
      "type": "object",
      "description": "Entity initiating/emitting this object.",
      "additionalProperties": false,
      "required": ["type", "id"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["user", "agent", "system"]
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "display_name": {
          "type": "string"
        }
      }
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 1
    },
    "event_id": {
      "type": "string"
    },
    "event_type": {
      "type": "string",
      "minLength": 1
    },
    "event_category": {
      "type": "string",
      "enum": ["execution", "policy", "approval", "system", "security"]
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "entity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id"],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "subtype": {
          "type": "string"
        }
      }
    },
    "payload_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary"],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "attributes": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "redacted_fields": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "if": {
    "properties": {
      "event_category": {
        "const": "execution"
      }
    },
    "required": ["event_category"]
  },
  "then": {
    "required": ["idempotency_key"]
  }
}
