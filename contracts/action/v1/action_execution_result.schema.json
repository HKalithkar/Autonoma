{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autonoma.ai/contracts/action/v1/action_execution_result.schema.json",
  "title": "ActionExecutionResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "correlation_id",
    "created_at",
    "actor",
    "idempotency_key",
    "action_request_id",
    "status",
    "timing"
  ],
  "properties": {
    "correlation_id": {
      "type": "string",
      "format": "uuid"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "actor": {
      "type": "object",
      "description": "Entity initiating/emitting this object.",
      "additionalProperties": false,
      "required": ["type", "id"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["user", "agent", "system"]
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "display_name": {
          "type": "string"
        }
      }
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 1
    },
    "action_execution_id": {
      "type": "string"
    },
    "action_request_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["succeeded", "failed", "partial", "cancelled"]
    },
    "outputs": {
      "type": "object",
      "additionalProperties": true
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "details": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "timing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["started_at", "finished_at", "duration_ms"],
      "properties": {
        "started_at": {
          "type": "string",
          "format": "date-time"
        },
        "finished_at": {
          "type": "string",
          "format": "date-time"
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
